  "private": true,
  "description": "MAST Part 3 — API Gateway + Job Queue + Worker Fleet powering Discover.",
  "type": "module",
  "scripts": {
    "dev:gateway": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/index.ts",
