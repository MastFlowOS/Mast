# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Opportunity Engine backend (Part 3 / mast-backend) — required for Discover
# to work. Points at the gateway's deployed URL (Railway/Render/Fly), not Supabase.
VITE_API_BASE_URL=https://your-mast-backend.up.railway.app

# --- Gateway-only (set these on the backend deployment, not the frontend) ---
# Required — see src/config/env.ts. The gateway process (npm run start:gateway
# / start:worker) exits at boot if any of these are missing.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_JWT_SECRET=your-jwt-secret
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#   Must be Supabase's SESSION pooler (Project Settings -> Database -> Connection
#   string -> Session pooler). pg-boss needs LISTEN/NOTIFY + session-scoped
#   prepared statements, which rules out the Transaction pooler (port 6543).
#   Do NOT use the "direct connection" host (db.<project-ref>.supabase.co) —
#   on projects without the paid IPv4 add-on it resolves to an IPv6 address
#   only, which Railway (no IPv6 egress) cannot route to (connect ENETUNREACH).
# ALLOWED_ORIGIN=https://your-frontend-domain.com
# PORT=8080

# Path to the mast-lead-engine checkout, for the worker's pythonBridge.ts
# subprocess calls. Defaults to "../mast-lead-engine" (sibling directory) —
# only override if your layout differs from the sibling-repo default.
# SCRAPER_ENGINE_PATH=../mast-lead-engine

# Phase 8 — AI Opportunity Intelligence. Optional: without it, /v1/intelligence's
# AI-backed endpoints (briefing, weekly, opportunities, coaching) return 503;
# Opportunity Explanations and everything else keep working.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
